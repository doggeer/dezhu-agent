# ===== 应用基础 =====
APP_NAME=dezhu-agent
ENV=development
LOG_LEVEL=INFO

# ===== API 配置 =====
BASE_URL=https://api.deepseek.com
API_KEY=sk-your-api-key
MODEL=deepseek-v4-pro
MAX_ITERATIONS=10

# ===== 数据存储 =====
DB_PATH=state.db

# ===== Prompt 组装 =====
# Hermes 目录，存放 SOUL.md / MEMORY.md / USER.md 等
HERMES_DIR=.hermes/
# 单文件读入 prompt 的最大字符数，超出截断
PROMPT_MAX_FILE_CHARS=20000

# ===== 上下文压缩 =====
# 估算 token 超过此阈值时触发压缩
COMPRESSION_THRESHOLD=50000
# 头部保护区消息数（user 首问 + 早期结果不参与压缩）
PROTECT_FIRST=3
# 最近 N 条 tool 输出保留原文，更早的替换为占位符
KEEP_RECENT_TOOL_RESULTS=3
# 尾部保护区的 token 预算（从末尾往前数）
TAIL_TOKEN_BUDGET=20000
# 摘要 LLM 调用的 max_tokens
SUMMARY_MAX_TOKENS=3000
# 喂给摘要器时，单条消息的截断字符上限
SUMMARY_PER_MSG_CHARS=2000
# 压缩后 token 数必须降到原值此比例以下，否则抛 CompressionStuckError
COMPRESSION_MIN_SHRINK=0.9
# 执行摘要的辅助模型（应便宜、快）
COMPRESSION_MODEL=deepseek-v4-flash
# 主模型的最大上下文窗口 token 数
MODEL_MAX_CONTEXT_TOKENS=65536
